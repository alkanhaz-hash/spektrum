rules_version = '2';

// SPEKTRUM Firestore Güvenlik Kuralları
// ---------------------------------------------------------------------------
// Bu kurallar Firebase altyapısında zorunlu kılınır; istemci kodu (SDK) bypass
// edilemez. Moderasyon ve veri bütünlüğü artık yalnızca uygulamaya değil, bu
// kurallara dayanır.
//
// DAĞITIM: bkz. artifacts/spektrum/FIREBASE_RULES.md
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isModerator() {
      return isSignedIn() && role() in ['moderator', 'admin'];
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function storyAuthor(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.authorId;
    }

    // ─── USERS ──────────────────────────────────────────────────────────────
    // Profiller herkese açık okunur. Kullanıcı yalnızca kendi profilini yazar
    // ve KENDİ ROLÜNÜ DEĞİŞTİREMEZ (yetki yükseltme engellenir).
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && request.resource.data.role == 'user';
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role)
                    || isModerator();
      allow delete: if isModerator();
    }

    // ─── STORIES ────────────────────────────────────────────────────────────
    // Sahibi tam yazabilir; diğer kullanıcılar yalnızca sayaç alanlarını
    // (beğeni/yorum/okunma) güncelleyebilir — içerik değiştiremez.
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid)
                    || isModerator()
                    || (isSignedIn() && changedKeys().hasOnly(['likeCount', 'commentCount', 'readCount']));
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── CHAPTERS ───────────────────────────────────────────────────────────
    // Bölümü yalnızca hikaye sahibi oluşturur/düzenler/siler ama KENDİ BÖLÜMÜNÜ
    // 'published'/'rejected' yapamaz — yalnızca 'draft' veya 'pending_review'
    // yazabilir. Yayına alma/reddetme yalnızca moderatöre aittir. Diğer
    // kullanıcılar yalnızca okunma sayacını artırabilir.
    match /chapters/{chapterId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && storyAuthor(request.resource.data.storyId) == request.auth.uid
                    && request.resource.data.status in ['draft', 'pending_review'];
      allow update: if isModerator()
                    || (isSignedIn()
                        && storyAuthor(resource.data.storyId) == request.auth.uid
                        && request.resource.data.status in ['draft', 'pending_review'])
                    || (isSignedIn() && changedKeys().hasOnly(['readCount']));
      allow delete: if isModerator()
                    || (isSignedIn() && storyAuthor(resource.data.storyId) == request.auth.uid);
    }

    // ─── STORY LIKES ────────────────────────────────────────────────────────
    match /storyLikes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isModerator();
    }

    // ─── INLINE COMMENTS ────────────────────────────────────────────────────
    match /inlineComments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid)
                    || isModerator()
                    || (isSignedIn() && changedKeys().hasOnly(['likeCount', 'likedBy']));
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── CONVERSATIONS ──────────────────────────────────────────────────────
    // Yalnızca katılımcılar okur/yazar.
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isModerator();
    }

    // ─── MESSAGES ───────────────────────────────────────────────────────────
    // Gönderen kendi adına yazar; yalnızca konuşmanın katılımcıları okur.
    match /messages/{messageId} {
      allow read: if isSignedIn()
                  && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants;
      allow update, delete: if (isSignedIn() && resource.data.senderId == request.auth.uid) || isModerator();
    }

    // ─── TALENT PORTFOLIOS ──────────────────────────────────────────────────
    match /talentPortfolios/{portfolioId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid)
                    || isModerator()
                    || (isSignedIn() && changedKeys().hasOnly(['likeCount']));
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isModerator();
    }

    // ─── NARRATION REQUESTS ─────────────────────────────────────────────────
    // Anlatıcı talep oluşturur; yalnızca hikaye sahibi onaylar/reddeder.
    match /narrationRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.narratorId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── NARRATIONS ─────────────────────────────────────────────────────────
    match /narrations/{narrationId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.narratorId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.narratorId == request.auth.uid) || isModerator();
    }

    // ─── ANONYMOUS QUESTIONS ────────────────────────────────────────────────
    // Soru gönderen kimliği saklanmaz (anonim). Cevaplanmış sorular herkese
    // açık; cevaplanmamışları yalnızca hedef kullanıcı görür ve cevaplar.
    match /anonymousQuestions/{questionId} {
      allow read: if resource.data.isAnswered == true || isOwner(resource.data.targetUid);
      allow create: if isSignedIn() && request.resource.data.isAnswered == false;
      allow update: if isOwner(resource.data.targetUid);
      allow delete: if isOwner(resource.data.targetUid) || isModerator();
    }

    // ─── DEFAULT DENY ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
