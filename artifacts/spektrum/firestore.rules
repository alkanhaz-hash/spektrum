rules_version = '2';

// SPEKTRUM Firestore Güvenlik Kuralları
// ---------------------------------------------------------------------------
// Bu kurallar Firebase altyapısında zorunlu kılınır; istemci kodu (SDK) bypass
// edilemez. Moderasyon ve veri bütünlüğü artık yalnızca uygulamaya değil, bu
// kurallara dayanır.
//
// DAĞITIM: bkz. artifacts/spektrum/FIREBASE_RULES.md
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isModerator() {
      return isSignedIn() && role() in ['moderator', 'admin'];
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Sayaç alanı (beğeni/yorum/okunma) yalnızca aynı kalabilir veya tam olarak
    // +1 / -1 değişebilir — keyfi değerlerle şişirme (sahte beğeni) engellenir.
    function counterDeltaOk(f) {
      return request.resource.data.get(f, 0) == resource.data.get(f, 0)
          || request.resource.data.get(f, 0) == resource.data.get(f, 0) + 1
          || request.resource.data.get(f, 0) == resource.data.get(f, 0) - 1;
    }

    function storyAuthor(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.authorId;
    }

    // ─── USERS ──────────────────────────────────────────────────────────────
    // Profiller herkese açık okunur. Kullanıcı yalnızca kendi profilini yazar
    // ve KENDİ ROLÜNÜ / BAN DURUMUNU DEĞİŞTİREMEZ (yetki yükseltme engellenir).
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && request.resource.data.role == 'user';
      // Kullanıcı kendi profilini günceller ama rolünü ve ban durumunu DEĞİŞTİREMEZ.
      // Moderatörler yalnızca banned/banReason alanlarını yazabilir.
      // Rol değişikliği YALNIZCA backend Admin SDK endpoint'i üzerinden yapılabilir.
      allow update: if (isOwner(uid)
                        && request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
                        && request.resource.data.get('banned', false) == resource.data.get('banned', false)
                        && request.resource.data.get('banReason', '') == resource.data.get('banReason', ''))
                    // Moderatörler ban/banReason alanlarını güncelleyebilir (rol dışında)
                    || (isModerator()
                        && request.resource.data.get('role', 'user') == resource.data.get('role', 'user'))
                    // Admin kullanıcılar başka kullanıcıların rolünü değiştirebilir
                    // (admin olmayan kullanıcıların rolü admin'e yükseltilemez)
                    || (isSignedIn()
                        && role() == 'admin'
                        && changedKeys().hasOnly(['role'])
                        && resource.data.get('role', 'user') != 'admin'
                        && request.resource.data.get('role', 'user') in ['user', 'moderator'])
                    // Herhangi bir giriş yapmış kullanıcı YALNIZCA takipçi/takip sayaçlarını güncelleyebilir
                    || (isSignedIn()
                        && changedKeys().hasOnly(['followerCount', 'followingCount'])
                        && counterDeltaOk('followerCount')
                        && counterDeltaOk('followingCount'));
      allow delete: if isModerator();
    }

    // ─── STORIES ────────────────────────────────────────────────────────────
    // Sahibi tam yazabilir; diğer kullanıcılar yalnızca sayaç alanlarını
    // (beğeni/yorum/okunma) güncelleyebilir — içerik değiştiremez.
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isSignedIn()
                        && resource.data.authorId == request.auth.uid
                        && request.resource.data.authorId == resource.data.authorId)
                    || isModerator()
                    || (isSignedIn()
                        && changedKeys().hasOnly(['likeCount', 'commentCount', 'readCount'])
                        && counterDeltaOk('likeCount')
                        && counterDeltaOk('commentCount')
                        && counterDeltaOk('readCount'));
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── CHAPTERS ───────────────────────────────────────────────────────────
    // Bölümü yalnızca hikaye sahibi oluşturur/düzenler/siler ama KENDİ BÖLÜMÜNÜ
    // 'published'/'rejected' yapamaz — yalnızca 'draft' veya 'pending_review'
    // yazabilir. Yayına alma/reddetme yalnızca moderatöre aittir. Diğer
    // kullanıcılar yalnızca okunma sayacını artırabilir.
    match /chapters/{chapterId} {
      // Yalnızca 'published' bölümler herkese açık. Taslak/incelemedeki/reddedilmiş
      // bölümleri yalnızca hikaye sahibi veya moderatör okuyabilir.
      allow read: if resource.data.status == 'published'
                  || isModerator()
                  || (isSignedIn() && storyAuthor(resource.data.storyId) == request.auth.uid);
      allow create: if isSignedIn()
                    && storyAuthor(request.resource.data.storyId) == request.auth.uid
                    && request.resource.data.status in ['draft', 'pending_review'];
      allow update: if isModerator()
                    || (isSignedIn()
                        && storyAuthor(resource.data.storyId) == request.auth.uid
                        && request.resource.data.storyId == resource.data.storyId
                        && request.resource.data.status in ['draft', 'pending_review'])
                    || (isSignedIn() && changedKeys().hasOnly(['readCount']) && counterDeltaOk('readCount'));
      allow delete: if isModerator()
                    || (isSignedIn() && storyAuthor(resource.data.storyId) == request.auth.uid);
    }

    // ─── STORY LIKES ────────────────────────────────────────────────────────
    match /storyLikes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isModerator();
    }

    // ─── INLINE COMMENTS ────────────────────────────────────────────────────
    // Beğeni güncellemesinde `likedBy` yalnızca isteği yapan kullanıcının kendi
    // UID'sini ekleyip çıkarabilir — başkası adına beğeni/geri alma engellenir.
    match /inlineComments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid)
                    || isModerator()
                    || (isSignedIn()
                        && changedKeys().hasOnly(['likeCount', 'likedBy'])
                        && counterDeltaOk('likeCount')
                        && resource.data.likedBy.toSet().difference(request.resource.data.likedBy.toSet())
                             .union(request.resource.data.likedBy.toSet().difference(resource.data.likedBy.toSet()))
                           == [request.auth.uid].toSet());
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── FOLLOWS ────────────────────────────────────────────────────────────
    // Takip eden kendi kaydını oluşturur/siler. ID formatı: {followerId}_{followedId}
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // ─── CONVERSATIONS ──────────────────────────────────────────────────────
    // Yalnızca katılımcılar okur/yazar. Güncellemede `participants` DEĞİŞTİRİLEMEZ
    // (yabancı kullanıcı ekleyip mesajları okuma yetkisi yükseltmesi engellenir);
    // yalnızca son mesaj alanları ve okunmamış sayacı yazılabilir.
    // NOT: resource == null kontrolü — henüz oluşturulmamış konuşma belgesi için
    // getDoc izin hatasını önler (getOrCreateConversation akışı).
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants
                    && changedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'unreadCount']);
      allow delete: if isModerator();
    }

    // ─── MESSAGES ───────────────────────────────────────────────────────────
    // Gönderen kendi adına yazar; yalnızca konuşmanın katılımcıları okur.
    match /messages/{messageId} {
      allow read: if isSignedIn()
                  && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants;
      // Gönderen kendi mesajını düzenleyebilir ama gönderen kimliğini/adını ve
      // konuşmayı DEĞİŞTİREMEZ (başka konuşmaya taşıma / kimlik sahteciliği engellenir).
      allow update: if (isSignedIn()
                        && resource.data.senderId == request.auth.uid
                        && request.resource.data.senderId == resource.data.senderId
                        && request.resource.data.senderName == resource.data.senderName
                        && request.resource.data.conversationId == resource.data.conversationId)
                    || isModerator();
      allow delete: if (isSignedIn() && resource.data.senderId == request.auth.uid) || isModerator();
    }

    // ─── TALENT PORTFOLIOS ──────────────────────────────────────────────────
    match /talentPortfolios/{portfolioId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid)
                    || isModerator()
                    || (isSignedIn() && changedKeys().hasOnly(['likeCount']) && counterDeltaOk('likeCount'));
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isModerator();
    }

    // ─── NARRATION REQUESTS ─────────────────────────────────────────────────
    // Anlatıcı talep oluşturur; yalnızca hikaye sahibi onaylar/reddeder.
    match /narrationRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.narratorId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isModerator();
    }

    // ─── NARRATIONS ─────────────────────────────────────────────────────────
    match /narrations/{narrationId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.narratorId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.narratorId == request.auth.uid) || isModerator();
    }

    // ─── ANONYMOUS QUESTIONS ────────────────────────────────────────────────
    // Soru gönderen kimliği saklanmaz (anonim). Cevaplanmış sorular herkese
    // açık; cevaplanmamışları yalnızca hedef kullanıcı görür ve cevaplar.
    match /anonymousQuestions/{questionId} {
      allow read: if resource.data.isAnswered == true || isOwner(resource.data.targetUid);
      allow create: if isSignedIn() && request.resource.data.isAnswered == false;
      allow update: if isOwner(resource.data.targetUid);
      allow delete: if isOwner(resource.data.targetUid) || isModerator();
    }

    // ─── BOOKMARKS ──────────────────────────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── NOTIFICATIONS ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.recipientId == request.auth.uid
                    && changedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    // ─── STATUSES ───────────────────────────────────────────────────────────
    // 24 saatlik kullanıcı durumları. Herkes okuyabilir; yalnızca sahibi oluşturur/siler.
    // viewedBy dizisine yalnızca kendi UID'sini ekleyebilir.
    match /statuses/{statusId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isModerator();
      // viewedBy güncellemesi: giriş yapmış herhangi biri sadece kendi UID'sini ekleyebilir
      allow update: if isSignedIn()
                    && changedKeys().hasOnly(['viewedBy'])
                    && request.resource.data.viewedBy.toSet().difference(resource.data.viewedBy.toSet())
                         == [request.auth.uid].toSet();
    }

    // ─── DEFAULT DENY ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
